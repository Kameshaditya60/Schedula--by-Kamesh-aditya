# Schedula environment configuration
# Copy this file to `.env` and fill in your local values.

# --- Database (PostgreSQL) ---
# DB port is hardcoded to 5433 in data-source.ts and app.module.ts.
db_host=localhost
db_username=postgres
db_password=your_password_here
db_name=schedula

# --- Auth ---
# Used to sign JWT access tokens. Use a long random string in production.
JWT_SECRET_KEY=change_me_to_a_random_secret

# --- Server ---
PORT=3000
